# Required when starting backend through the root docker-compose.yml.
# Copy this file to backend/.env, then fill real values.

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Public HTTPS URL of the Mini App.
# Also configure this domain in BotFather with /setdomain.
TELEGRAM_WEBAPP_URL=

# 32-byte AES key encoded as 64 hex characters.
# Example generator: openssl rand -hex 32
ENCRYPTION_KEY=

# SoSoValue news API. The backend syncs news into MySQL and keeps only 24 hours of rows.
SOSO_VALUE_API_KEY=
SOSO_VALUE_API_BASE_URL=https://openapi.sosovalue.com
SOSO_VALUE_NEWS_SYNC_ENABLED=1
SOSO_VALUE_NEWS_SYNC_INTERVAL_SECONDS=60
SOSO_VALUE_NEWS_PAGE_SIZE=30
SOSO_VALUE_NEWS_CATEGORY_LIST=1,2,3,4,5,6,7,9,10
SOSO_VALUE_NEWS_TICKER_CATEGORY_LIST=13
SOSO_VALUE_NEWS_MONTHLY_SAFETY_LIMIT=95000
SOSO_VALUE_NEWS_FEATURED_ENDPOINT=/api/v1/news/featured/currency
# Uses the same news endpoint by default, with SOSO_VALUE_NEWS_TICKER_CATEGORY_LIST as its categoryList.
SOSO_VALUE_NEWS_TICKER_ENDPOINT=/api/v1/news/featured/currency
