# Telegram Bot Token（必填）
TELEGRAM_BOT_TOKEN=

# Telegram Mini App / WebApp 地址（可选；建议使用稳定的 Production 域名；需要 https）
TELEGRAM_WEBAPP_URL=

# Telegram 菜单按钮模式：
# - commands：显示命令菜单（默认）
# - web_app：将菜单按钮替换为 WebApp（会隐藏命令入口）
# - default：恢复 Telegram 默认行为
TELEGRAM_MENU_BUTTON_MODE=commands

# Access Control：管理员钱包地址（绑定该钱包的用户拥有管理员权限）
ADMIN_WALLET_ADDRESS=

# BSC Network：RPC 节点地址
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
# BSC ChainID（主网=56）
BSC_CHAIN_ID=56

# Uniswap V4：PoolManager 合约地址（必填：V4 功能需要）
UNISWAP_V4_POOL_MANAGER_ADDRESS=
# Uniswap V4：StateView 合约地址（用于读取 tick/状态）
UNISWAP_V4_STATE_VIEW_ADDRESS=
# Uniswap V4：PositionManager 合约地址（V4 NFT 相关）
UNISWAP_V4_POSITION_MANAGER_ADDRESS=
# Uniswap V4：调试日志开关（0/1）
UNISWAP_V4_DEBUG=0

# OKX DEX API：基础 URL
OKX_DEX_API_URL=https://www.okx.com/api/v6/dex/aggregator
# OKX API Key（必填：启用 OKX swap 时）
OKX_API_KEY=
# OKX Secret Key（必填：启用 OKX swap 时）
OKX_SECRET_KEY=
# OKX Passphrase（必填：启用 OKX swap 时）
OKX_PASSPHRASE=

# OKX 安全校验（可选）：强制 OKX /swap 返回的 tx.to 必须等于该 Router
OKX_SWAP_ROUTER=
# OKX TokenApprove 合约地址（可选；不填则由 OKX API 动态返回 approveTarget）
OKX_TOKEN_APPROVE_ADDRESS=
# OKX 调试日志开关（0/1）
OKX_DEBUG=0

# ZapV3V4Improved 合约地址（部署后填写；V3/V4 可以填同一个地址）
ZAP_V3_ADDRESS=
ZAP_V4_ADDRESS=

# V3 Position Managers（可选；用于某些链上交互/显示）
PANCAKE_V3_NPM_ADDRESS=
UNISWAP_V3_NPM_ADDRESS=

# V4 NFT 扫描优化（可选）：从指定区块开始扫 Transfer 日志（0=从头/不限制）
V4_NFT_SCAN_FROM_BLOCK=0

# Database (MySQL)：主机
MYSQL_HOST=localhost
# Database (MySQL)：端口
MYSQL_PORT=3306
# Database (MySQL)：用户名
MYSQL_USER=root
# Database (MySQL)：密码
MYSQL_PASSWORD=
# Database (MySQL)：数据库名
MYSQL_DATABASE=tglpbot

# Redis：主机
REDIS_HOST=localhost
# Redis：端口
REDIS_PORT=6379
# Redis：密码（无密码可留空）
REDIS_PASSWORD=
# Redis：DB（数字）
REDIS_DB=0

# ClickHouse（可选；用于 PoolM 历史/分析等）地址
CLICKHOUSE_ADDR=localhost:9000
# ClickHouse 协议：native|http（留空自动根据端口推断：9000/19000->native，8123/18123->http）
CLICKHOUSE_PROTOCOL=
# ClickHouse：数据库名
CLICKHOUSE_DB=default
# ClickHouse：用户名
CLICKHOUSE_USER=default
# ClickHouse：密码
CLICKHOUSE_PASSWORD=
# ClickHouse：调试日志开关（0/1）
CLICKHOUSE_DEBUG=0
# ⚠️危险：启动时删除 CLICKHOUSE_DB 下所有表并重建（只跑一次，跑完立即关）
CLICKHOUSE_RESET_ALL=0

# 钱包私钥加密 Key（32 bytes hex，必填；否则程序启动会失败）
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Gas：最大 GasPrice（Wei）
MAX_GAS_PRICE=10000000000
# Gas：默认 GasLimit
GAS_LIMIT=5000000

# PancakeSwap V2：Router 地址（BSC）
PANCAKE_ROUTER_V2=0x10ED43C718714eb63d5aA57B78B54704E256024E
# PancakeSwap V2：Factory 地址（BSC）
PANCAKE_FACTORY_V2=0xcA143Ce32Fe78f1f7019d7d551a6402fC5350c73

# 常用 Token 地址（BSC）
# USDT 地址
USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
# USDC 地址
USDC_ADDRESS=0x8ac76a51cc950d9822d68b83fe1ad97b32cd580d
# BUSD 地址
BUSD_ADDRESS=0xe9e7CEA3DedcA5984780Bafc599bD69ADd087D56
# WBNB 地址
WBNB_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c

# V3 Swap Router（链上 swap 用；可选）
PANCAKE_V3_SWAP_ROUTER=0x1b81D678ffb9C0263b24A97847620C99d213eB14
UNISWAP_V3_SWAP_ROUTER=0xB971eF87ede563556b2ED4b1C0b0019111Dd85d2

# ==========================
# Auto LP (PoolM scanner V1)
# ==========================
# 安全建议：默认只扫描不交易；先开扫描观察日志，再开启自动开仓
# 是否启用 AutoLP 扫描（0/1）
AUTO_LP_ENABLED=0
# 是否允许自动开仓（0/1；危险开关）
AUTO_LP_EXECUTE_ENABLED=0

# 是否每轮推送候选池 Top1 到 Telegram（0/1；间隔小会刷屏）
AUTO_LP_NOTIFY_TOP_CANDIDATE=0

# 是否输出详细调试日志到控制台（0/1）
AUTO_LP_DEBUG=0

# PoolM API BaseURL（默认 https://mapi.poolm.xyz；一般不用改）
AUTO_LP_POOLM_BASE_URL=

# 扫描配置：链（默认 bsc）
AUTO_LP_CHAIN=bsc
# 扫描配置：DEX 列表（逗号分隔，例如 pcsv3,univ3,univ4）
AUTO_LP_PROTOCOLS=pcsv3,univ3,univ4
# 扫描配置：短周期（分钟；保留字段，当前固定会拉 5/15/60/360）
AUTO_LP_TIMEFRAME_SHORT_MINUTES=5
# 扫描配置：长周期（分钟；保留字段，当前固定会拉 5/15/60/360）
AUTO_LP_TIMEFRAME_LONG_MINUTES=60
# 扫描间隔（秒；默认 60）
AUTO_LP_SCAN_INTERVAL_SECONDS=60

# 执行目标用户：
# - AUTO_LP_USER_ID>0：直接指定 user_id
# - 否则：通过 ADMIN_WALLET_ADDRESS 在 wallets 表中反查 user_id
AUTO_LP_USER_ID=0

# 执行参数：单次投入 USDT（>0 才会执行开仓）
AUTO_LP_AMOUNT_USDT=0
# 执行参数：基础宽度（百分比；例如 5 表示 5%）
AUTO_LP_BASE_WIDTH_PERCENT=5
# 执行参数：允许的最大活跃自动任务数
AUTO_LP_MAX_ACTIVE_TASKS=1
# 执行参数：池子不含 USDT 时是否允许入场 swap（0/1）
AUTO_LP_ALLOW_ENTRY_SWAP=1

# 紧急 Gas 倍数（遇到 CRASH/RAPID_PUMP 会提高 gas；例如 2.0）
AUTO_LP_EMERGENCY_GAS_MULTIPLIER=2.0

# 硬筛过滤（0=不限制；字段对应 PoolM 5m 数据）
# - AUTO_LP_MIN_POOL_VALUE_USD 对应 current_pool_value（USD）
AUTO_LP_MIN_POOL_VALUE_USD=50000
# - AUTO_LP_MIN_FEE_PERCENTAGE 对应 fee_percentage（%）
AUTO_LP_MIN_FEE_PERCENTAGE=0.2
# - AUTO_LP_MIN_FEE_RATE_5M 对应 total_fees/current_pool_value（%）
AUTO_LP_MIN_FEE_RATE_5M=0
# - AUTO_LP_MIN_TOTAL_FEES_5M 对应 total_fees（5m）
AUTO_LP_MIN_TOTAL_FEES_5M=100
# - AUTO_LP_MIN_TOTAL_VOLUME_5M 对应 total_volume（5m）
AUTO_LP_MIN_TOTAL_VOLUME_5M=5000
# - AUTO_LP_MIN_TX_5M 对应 transaction_count（5m）
AUTO_LP_MIN_TX_5M=0
# - AUTO_LP_MIN_TX_60M 对应 transaction_count（60m）
AUTO_LP_MIN_TX_60M=0
# - AUTO_LP_MIN_FEE_APR_5M/60M：预留（当前未启用）
AUTO_LP_MIN_FEE_APR_5M=0
AUTO_LP_MIN_FEE_APR_60M=0
# - AUTO_LP_MAX_SURGE_RATIO：预留（当前未启用）
AUTO_LP_MAX_SURGE_RATIO=0
# 最多保留多少个候选池参与排序
AUTO_LP_MAX_CANDIDATES=20

# ========== SmartLP（监听外部合约 -> 解析 V3/V4 LP 事件）==========
# 开关（0/1）
SMART_LP_ENABLED=false
# 详细日志（0/1）
SMART_LP_DEBUG=false
# 需要监听的合约地址（支持逗号/空格分隔多个）
SMART_LP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# 扫描间隔（秒；默认 60）
SMART_LP_SCAN_INTERVAL_SECONDS=60
# 每次扫描最多处理多少个区块（默认 200；想“单块扫描”可设为 1）
SMART_LP_MAX_BLOCKS_PER_SCAN=200
# 单次 RPC 请求超时（秒；默认 30）
SMART_LP_RPC_TIMEOUT_SECONDS=30
# 单轮扫描总超时（秒；默认 600）
SMART_LP_SCAN_TIMEOUT_SECONDS=600

# 共振门槛（独立于硬筛；0=不限制）
# - AUTO_LP_RESONANCE_MIN_FEE_RATE_5M 对应 total_fees/current_pool_value（%）
AUTO_LP_RESONANCE_MIN_FEE_RATE_5M=0
# - AUTO_LP_RESONANCE_MIN_TOTAL_VOLUME_5M 对应 total_volume（5m）
AUTO_LP_RESONANCE_MIN_TOTAL_VOLUME_5M=0
# - AUTO_LP_RESONANCE_MIN_ABS_Z60 对应 |Z60|
AUTO_LP_RESONANCE_MIN_ABS_Z60=0

# 稳定币符号过滤（保留字段：当前版本已移除 stable_coin_symbol 的筛选，不生效）
AUTO_LP_REQUIRE_STABLE_SYMBOL=USDT

# 状态对应开仓宽度（总宽度，百分比；用于开仓时计算 tick 区间）
# - 震荡(SIDEWAYS)：建议更窄，提高资金利用率
AUTO_LP_WIDTH_SIDEWAYS_PERCENT=2.0
# - 温和上涨(MILD_UPTREND)：中等宽度 + 非对称（下 20% / 上 80%）
AUTO_LP_WIDTH_MILD_UPTREND_PERCENT=5.0
# - 急涨(RAPID_PUMP)：更宽 + 贴边（下 10% / 上 90%），多吃涨幅
AUTO_LP_WIDTH_RAPID_PUMP_PERCENT=15.0

# 退出卫士（窗口内按 5m 数据计算）
AUTO_LP_GUARD_VOLUME_DROP_PERCENT=0.30
# - 手续费率保护：若 5m 手续费/TVL（total_fees/current_pool_value，%）高于阈值，则不因“成交量回落”触发撤退（0=关闭）
AUTO_LP_GUARD_NO_EXIT_MIN_FEE_RATE_5M=0
# - 低手续费率策略：若 5m 手续费/TVL 低于阈值，则“成交量回落”改用另一个阈值（0=关闭）
AUTO_LP_GUARD_LOW_FEE_RATE_5M=0
AUTO_LP_GUARD_VOLUME_DROP_PERCENT_LOW_FEE=0
# - 触发 2：窗口内 价格+交易笔数 相对峰值下跌比例（0.10=10%）
AUTO_LP_GUARD_PRICE_TX_DROP_PERCENT=0.10

# API 请求间隔（毫秒；降低 429 风险。若频繁 429，可调到 1000~3000）
AUTO_LP_FETCH_DELAY_MILLIS=250
