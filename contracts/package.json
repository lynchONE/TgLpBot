{
  "name": "tglpbot-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for TgLpBot",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network bscTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network bsc",
    "deploy-zap:testnet": "hardhat run scripts/deploy_zap_simple.js --network bscTestnet",
    "deploy-zap:mainnet": "hardhat run scripts/deploy_zap_simple.js --network bsc",
    "deploy-zap:base": "hardhat run scripts/deploy_zap_simple.js --network base",
    "deploy-zap:baseSepolia": "hardhat run scripts/deploy_zap_simple.js --network baseSepolia",
    "update-trusted:bsc": "hardhat run scripts/update_trusted.js --network bsc",
    "update-trusted:base": "hardhat run scripts/update_trusted.js --network base",
    "update-trusted:baseSepolia": "hardhat run scripts/update_trusted.js --network baseSepolia",
    "read-config:bsc": "hardhat run scripts/read_config.js --network bsc",
    "read-config:base": "hardhat run scripts/read_config.js --network base",
    "read-config:baseSepolia": "hardhat run scripts/read_config.js --network baseSepolia",
    "verify:testnet": "hardhat verify --network bscTestnet",
    "verify:mainnet": "hardhat verify --network bsc",
    "verify:base": "hardhat verify --network base",
    "verify:baseSepolia": "hardhat verify --network baseSepolia"
  },
  "devDependencies": {
    "dotenv": "^16.3.1",
    "ethers": "^6.4.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^1.0.0",
    "hardhat": "^2.19.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@uniswap/v4-core": "^1.0.2",
    "@uniswap/v4-periphery": "^1.0.3"
  }
}
