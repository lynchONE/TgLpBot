# Optional root-level Docker Compose overrides.
# Copy this file to .env if you need to change ports or local middleware credentials.

BACKEND_PORT=8080
WEBAPP_PORT=3000
MINIAPP_PORT=3001

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

COMPOSE_MYSQL_ROOT_PASSWORD=tglpbot_dev_password
COMPOSE_MYSQL_DATABASE=tglpbot

COMPOSE_MINIO_ROOT_USER=minioadmin
COMPOSE_MINIO_ROOT_PASSWORD=minioadmin123
COMPOSE_MINIO_PUBLIC_BASE_URL=http://localhost:9000
COMPOSE_MINIO_AVATAR_BUCKET=avatar

# Leave empty for localhost builds. The frontends will call http://localhost:8080.
WEBAPP_VITE_API_BASE_URL=
WEBAPP_VITE_WS_BASE_URL=
WEBAPP_VITE_DEFAULT_CHAIN=bsc
WEBAPP_VITE_TELEGRAM_BOT_ID=
WEBAPP_VITE_TELEGRAM_BOT_USERNAME=
MINIAPP_VITE_API_BASE_URL=
MINIAPP_VITE_ALLOW_EMPTY_INITDATA=
