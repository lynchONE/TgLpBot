# Docker Compose middleware environment example for the repository root.
# Copy this file to `.env` next to `docker-compose.yml`.
#
# This file is only used by Docker Compose for interpolation:
# - middleware host ports
# - middleware passwords
#
# Backend, MiniApp, and WebApp are not started by this compose file.

# MinIO public host ports: 9000 is object API, 9001 is console.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Middleware host bind addresses.
# Keep 127.0.0.1 unless external tools must connect directly to MySQL/Redis.
# If changed to 0.0.0.0, protect the ports with firewall rules.
MYSQL_BIND_ADDR=0.0.0.0
MYSQL_PORT=3306
REDIS_BIND_ADDR=0.0.0.0
REDIS_PORT=6379

# MySQL settings used by the mysql container.
COMPOSE_MYSQL_ROOT_PASSWORD=540623lp
COMPOSE_MYSQL_DATABASE=tg_auto_lp_bot
# Redis password used by the redis container.
# Leave empty only for local trusted development.
COMPOSE_REDIS_PASSWORD=540623lp

# MinIO settings used by the minio container and bucket initializer.
COMPOSE_MINIO_ROOT_USER=admin
COMPOSE_MINIO_ROOT_PASSWORD=540623lp
COMPOSE_MINIO_AVATAR_BUCKET=avatar
