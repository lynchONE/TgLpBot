# 根目录 Docker Compose 配置示例。
# 复制为 .env 后修改；这里主要控制宿主机端口、中间件账号密码、前端构建参数。

# 对外暴露的应用端口。
BACKEND_PORT=8080
WEBAPP_PORT=3000
MINIAPP_PORT=3001

# MinIO 对外端口：9000 是对象 API，9001 是控制台。
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 中间件端口绑定地址。
# 0.0.0.0 表示允许远程工具通过服务器 IP 连接；127.0.0.1 表示只允许服务器本机连接。
MYSQL_BIND_ADDR=0.0.0.0
MYSQL_PORT=3306
REDIS_BIND_ADDR=0.0.0.0
REDIS_PORT=6379

# MySQL root 密码和数据库名。公网开放时必须改成强密码。
COMPOSE_MYSQL_ROOT_PASSWORD=change_me_strong_mysql_password
COMPOSE_MYSQL_DATABASE=tglpbot

# Redis 密码。公网开放时必须填写强密码；后端容器会自动使用同一个密码连接 Redis。
COMPOSE_REDIS_PASSWORD=change_me_strong_redis_password

# MinIO 管理员账号密码，以及后端生成头像/对象访问 URL 时使用的公网基础地址。
COMPOSE_MINIO_ROOT_USER=admin
COMPOSE_MINIO_ROOT_PASSWORD=minioadmin123
COMPOSE_MINIO_PUBLIC_BASE_URL=http://localhost:9000
COMPOSE_MINIO_AVATAR_BUCKET=avatar

# WebApp 前端构建参数。它们会在 docker build 时写入前端静态包。
# 当前 compose 的 webapp 容器自带 nginx /api 反向代理；同域部署时 API/WS 可以留空。
#
# WebApp 调后端 API 的公网基础地址。
# 留空：浏览器按当前域名访问 /api，由 webapp nginx 转发到 backend。
# 跨域部署或不用内置 nginx 代理时填写，例如 https://api.example.com。
WEBAPP_VITE_API_BASE_URL=

# WebApp WebSocket 公网基础地址。
# 留空：前端按当前域名推导；跨域 WS 时填写，例如 wss://api.example.com。
WEBAPP_VITE_WS_BASE_URL=

# WebApp 默认链。当前常用 bsc；多链页面只是默认选中值，不影响后端可用链配置。
WEBAPP_VITE_DEFAULT_CHAIN=bsc

# Telegram 登录/跳转相关展示配置：Bot 的数字 ID。
# 只有 webapp 需要展示或拼接 Telegram bot 入口时才填；纯 miniapp 可留空。
WEBAPP_VITE_TELEGRAM_BOT_ID=

# Telegram 登录/跳转相关展示配置：Bot 用户名，不带 @。
# 只有 webapp 需要展示或拼接 Telegram bot 入口时才填；纯 miniapp 可留空。
WEBAPP_VITE_TELEGRAM_BOT_USERNAME=

# MiniApp 前端构建参数。它们会在 docker build 时写入 miniapp 静态包。
# 当前 compose 的 miniapp 容器自带 nginx /api 反向代理；同域部署时 API 可以留空。
#
# MiniApp 调后端 API 的公网基础地址。
# 留空：Telegram 打开的页面按当前域名访问 /api，由 miniapp nginx 转发到 backend。
# 如果 miniapp 静态页面和 backend 不在同一域名/代理下，填写后端 HTTPS 地址。
MINIAPP_VITE_API_BASE_URL=

# 是否允许缺少 Telegram initData。
# 仅本地调试使用可设 1；生产 Telegram Mini App 必须留空或设 0。
MINIAPP_VITE_ALLOW_EMPTY_INITDATA=
